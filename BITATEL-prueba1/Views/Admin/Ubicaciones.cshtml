@model IEnumerable<BITATEL_prueba1.Controllers.AdminController.ClienteSedesItem>
@{
    ViewBag.Title = "Infraestructura: Sedes";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<style>
    .modal-overlay {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0,0,0,0.5);
        z-index: 2000;
        align-items: center;
        justify-content: center;
    }

    .modal-box {
        background: white;
        padding: 30px;
        border-radius: 8px;
        width: 450px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.2);
    }

    .form-group {
        margin-bottom: 15px;
    }

        .form-group label {
            display: block;
            margin-bottom: 5px;
            font-weight: bold;
            color: #4b5563;
            font-size: 0.9rem;
        }

        .form-group input, .form-group select, .form-group textarea {
            width: 100%;
            padding: 10px;
            border: 1px solid #cbd5e1;
            border-radius: 5px;
            font-family: inherit;
            box-sizing: border-box;
        }
</style>

<div style="max-width: 1400px; margin: 0 auto; padding-bottom: 40px;">

    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
        <div>
            <h2 style="color: #333; margin: 0;">Sedes y Ubicaciones Físicas</h2>
            <p style="color: #666; margin-top: 5px;">Gestión de infraestructura agrupada por cliente.</p>
        </div>
        <button onclick="document.getElementById('modalNuevaSede').style.display='flex'" style="background-color: #10b981; color: white; border: none; padding: 12px 25px; border-radius: 5px; font-weight: bold; cursor: pointer; box-shadow: 0 4px 6px rgba(0,0,0,0.1); display: flex; align-items: center; gap: 8px;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
            Añadir Nueva Sede
        </button>
    </div>

    <!-- BUSCADOR UNIVERSAL TURBO -->
    <div style="margin-bottom: 30px; max-width: 400px; position: relative;">
        <svg style="position: absolute; left: 12px; top: 12px; color: #94a3b8;" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
        <input type="text" id="txtBuscarUniversal" onkeyup="filtrarTarjetas()" placeholder="Buscar empresa o RUC..." style="width: 100%; padding: 10px 10px 10px 40px; border: 1px solid #cbd5e1; border-radius: 5px; font-family: inherit; font-size: 0.95rem;">
    </div>

    <!-- GRILLA DE TARJETAS (ESTILO DASHBOARD) -->
    <div id="gridClientes" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 20px;">
        @foreach (var c in Model)
        {
            <div class="card-cliente" style="background: white; border-radius: 8px; border: 1px solid #e2e8f0; padding: 25px; box-shadow: 0 2px 5px rgba(0,0,0,0.02); transition: transform 0.2s, box-shadow 0.2s;" onmouseover="this.style.transform='translateY(-5px)'; this.style.boxShadow='0 10px 15px rgba(0,0,0,0.05)';" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 2px 5px rgba(0,0,0,0.02)';">

                <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 15px;">
                    <div style="background: #eff6ff; padding: 10px; border-radius: 8px; color: #3b82f6;">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
                    </div>
                    <span style="background: #f1f5f9; color: #475569; padding: 4px 10px; border-radius: 20px; font-size: 0.8rem; font-weight: bold; border: 1px solid #e2e8f0;">
                        RUC: @c.Ruc
                    </span>
                </div>

                <h3 class="card-nombre" style="margin: 0 0 5px 0; color: #1e293b; font-size: 1.2rem;">@c.NombreEmpresa</h3>
                <p style="margin: 0 0 20px 0; color: #64748b; font-size: 0.9rem;">
                    <strong>@c.TotalSedes</strong> Sedes / Sucursales Registradas
                </p>

                <a href="@Url.Action("SedesCliente", "Admin", new { id = c.IdCliente })" style="display: block; text-align: center; background-color: #f8fafc; color: #3b82f6; border: 1px solid #bfdbfe; text-decoration: none; padding: 10px; border-radius: 5px; font-weight: bold; transition: background 0.3s;" onmouseover="this.style.backgroundColor='#eff6ff'" onmouseout="this.style.backgroundColor='#f8fafc'">
                    Gestionar Sedes ➔
                </a>
            </div>
        }
    </div>
</div>

<!-- MODAL CREAR SEDE GLOBAL -->
<div id="modalNuevaSede" class="modal-overlay">
    <div class="modal-box">
        <h3 style="margin-top:0; color:#1e40af; border-bottom:1px solid #eee; padding-bottom:10px;">Añadir Nueva Sede</h3>

        <div class="form-group">
            <label>1. Cliente Propietario *</label>
            @Html.DropDownList("idClienteGlobal", (IEnumerable<SelectListItem>)ViewBag.ListaClientes, "Seleccione la empresa...", new { id = "cboClienteGlobal" })
        </div>
        <div class="form-group">
            <label>2. Nombre de la Sede *</label>
            <input type="text" id="txtNomSedeGlobal" placeholder="Ej: Torre Principal San Isidro">
        </div>
        <div class="form-group">
            <label>3. Departamento / Ciudad</label>
            <input type="text" id="txtDepSedeGlobal" placeholder="Ej: Lima">
        </div>
        <div class="form-group">
            <label>4. Observación (Opcional)</label>
            <textarea id="txtObsSedeGlobal" rows="3" placeholder="Detalles de acceso, horarios, etc."></textarea>
        </div>

        <div style="text-align: right; margin-top: 20px;">
            <button onclick="document.getElementById('modalNuevaSede').style.display='none'" style="padding: 10px 15px; cursor:pointer; background:#f1f5f9; color:#475569; border:none; border-radius:5px; font-weight:bold; margin-right:10px;">Cancelar</button>
            <button onclick="guardarSedeGlobal()" style="padding: 10px 20px; cursor:pointer; background:#10b981; color:white; border:none; border-radius:5px; font-weight:bold;">Guardar Sede</button>
        </div>
    </div>
</div>

<script>
    // Buscador Universal para Tarjetas
    function filtrarTarjetas() {
        var texto = document.getElementById("txtBuscarUniversal").value.toLowerCase();
        var tarjetas = document.querySelectorAll(".card-cliente");

        tarjetas.forEach(function (tarjeta) {
            // Buscamos dentro de todo el texto de la tarjeta
            var coincide = tarjeta.textContent.toLowerCase().includes(texto);
            tarjeta.style.display = coincide ? "block" : "none";
        });
    }

    // Guardar Sede Vía AJAX
    function guardarSedeGlobal() {
        var idCli = document.getElementById('cboClienteGlobal').value;
        var nom = document.getElementById('txtNomSedeGlobal').value;
        var dep = document.getElementById('txtDepSedeGlobal').value;
        var obs = document.getElementById('txtObsSedeGlobal').value;

        if (!idCli || !nom) {
            alert("Por favor, seleccione el cliente y escriba el nombre de la sede.");
            return;
        }

        fetch('/Admin/GuardarSede', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ idCliente: idCli, nombreSede: nom, departamento: dep, observacion: obs })
        }).then(res => res.json()).then(data => {
            if (data.success) {
                alert("Sede registrada correctamente.");
                // Redirigir al detalle del cliente recién seleccionado para que vea su nueva sede
                window.location.href = '/Admin/SedesCliente/' + idCli;
            } else {
                alert("Error: " + data.message);
            }
        });
    }
</script>