@model IEnumerable<BITATEL_prueba1.Controllers.AdminController.ClienteStockItem>
@{
    string filtro = ViewBag.Filtro as string ?? "todo";
    ViewBag.Title = filtro == "produccion" ? "Inventario en Producción" : "Inventario General";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div style="max-width: 1400px; margin: 0 auto; padding-bottom: 40px;">

    <div style="margin-bottom: 30px;">
        <h2 style="color: #333; margin: 0;">@ViewBag.Title</h2>
        <p style="color: #666; margin-top: 5px;">
            @(filtro == "produccion" ? "Listado de empresas con hardware en operación." : "Vista global de hardware en stock y asignado a clientes.")
        </p>
    </div>

    <div style="margin-bottom: 20px; max-width: 400px; position: relative;">
        <svg style="position: absolute; left: 12px; top: 12px; color: #94a3b8;" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
        <input type="text" id="txtBuscarUniversal" onkeyup="filtrarTarjetas()" placeholder="Buscar cliente..." style="width: 100%; padding: 10px 10px 10px 40px; border: 1px solid #cbd5e1; border-radius: 5px; font-family: inherit;">
    </div>

    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 20px;">

        @if (filtro != "produccion")
        {
            <div class="card-cliente" style="background: white; border-radius: 8px; border: 1px solid #10b981; border-left: 5px solid #10b981; padding: 25px; box-shadow: 0 2px 5px rgba(0,0,0,0.02);">
                <h3 style="margin: 0 0 5px 0; color: #1e293b; font-size: 1.2rem;">Almacén BITATEL</h3>
                <p style="margin: 0 0 10px 0; color: #64748b; font-size: 0.85rem;">Hardware en stock físico listo para despachar.</p>
                <div style="font-size: 1.8rem; font-weight: bold; color: #10b981; margin-bottom: 15px;">@ViewBag.TotalStock</div>

                <a href="@Url.Action("StockLocal", "Admin")" style="display: block; text-align: center; background-color: #f0fdf4; color: #166534; border: 1px solid #bbf7d0; text-decoration: none; padding: 10px; border-radius: 5px; font-weight: bold; transition: background 0.3s;" onmouseover="this.style.backgroundColor='#dcfce7'" onmouseout="this.style.backgroundColor='#f0fdf4'">
                    Ver Inventario Disponible
                </a>
            </div>
        }

        @foreach (var c in Model)
        {
            <div class="card-cliente" style="background: white; border-radius: 8px; border: 1px solid #e2e8f0; border-left: 5px solid #3b82f6; padding: 25px; box-shadow: 0 2px 5px rgba(0,0,0,0.02); transition: transform 0.2s, box-shadow 0.2s;" onmouseover="this.style.transform='translateY(-5px)'; this.style.boxShadow='0 10px 15px rgba(0,0,0,0.05)';" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 2px 5px rgba(0,0,0,0.02)';">
                <h3 class="card-nombre" style="margin: 0 0 5px 0; color: #1e293b; font-size: 1.2rem;">@c.NombreEmpresa</h3>
                <p style="margin: 0 0 10px 0; color: #64748b; font-size: 0.85rem;">Equipos activos en producción</p>
                <div style="font-size: 1.8rem; font-weight: bold; color: #3b82f6; margin-bottom: 15px;">@c.EquiposActivos</div>

                <a href="@Url.Action("InventarioCliente", "Admin", new { id = c.IdCliente })" style="display: block; text-align: center; background-color: #eff6ff; color: #1d4ed8; border: 1px solid #bfdbfe; text-decoration: none; padding: 10px; border-radius: 5px; font-weight: bold; transition: background 0.3s;" onmouseover="this.style.backgroundColor='#dbeafe'" onmouseout="this.style.backgroundColor='#eff6ff'">
                    Ver Inventario del Cliente
                </a>
            </div>
        }
    </div>
</div>

<script>
    function filtrarTarjetas() {
        var texto = document.getElementById("txtBuscarUniversal").value.toLowerCase();
        document.querySelectorAll(".card-cliente").forEach(function (tarjeta) {
            tarjeta.style.display = tarjeta.textContent.toLowerCase().includes(texto) ? "block" : "none";
        });
    }
</script>