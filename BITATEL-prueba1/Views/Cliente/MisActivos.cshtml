@model IEnumerable<BITATEL_prueba1.Controllers.ClienteController.ActivoClienteItem>
@using System.Linq
@{
    ViewBag.Title = "Mis Activos Fijos";
    Layout = "~/Views/Shared/_LayoutCliente.cshtml";

    var ubicacionesAgrupadas = Model
        .GroupBy(x => x.Ubicacion.Split('-')[0].Trim())
        .ToDictionary(g => g.Key, g => g.Select(x => x.Ubicacion).Distinct().OrderBy(x => x).ToList());

    var categoriasUnicas = Model.Select(x => x.Categoria).Distinct().OrderBy(x => x).ToList();
    var marcasUnicas = Model.Select(x => x.Marca).Distinct().OrderBy(x => x).ToList();
}

<style>
    .modal-overlay {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0,0,0,0.5);
        z-index: 2000;
        align-items: center;
        justify-content: center;
    }

    .modal-box {
        background: white;
        padding: 25px;
        border-radius: 8px;
        width: 400px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.2);
    }

    .page-title {
        margin-top: 0;
        color: #1f2937;
        font-size: 1.8rem;
        font-weight: 600;
        margin-bottom: 25px;
    }

    .toolbar {
        display: flex;
        justify-content: space-between;
        margin-bottom: 20px;
        align-items: center;
        flex-wrap: wrap;
        gap: 15px;
    }

    .toolbar-group {
        display: flex;
        gap: 12px;
        align-items: center;
    }

    .btn-action {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 10px 16px;
        border-radius: 6px;
        border: none;
        font-size: 0.9rem;
        font-weight: bold;
        cursor: pointer;
        transition: all 0.2s ease;
        box-shadow: 0 1px 2px rgba(0,0,0,0.05);
    }

        .btn-action:active {
            transform: scale(0.97);
        }

        .btn-action svg {
            width: 18px;
            height: 18px;
            fill: none;
            stroke: currentColor;
            stroke-width: 2;
            stroke-linecap: round;
            stroke-linejoin: round;
        }

    .btn-new {
        background-color: #10b981;
        color: white;
    }

        .btn-new:hover {
            background-color: #059669;
            box-shadow: 0 4px 6px rgba(16, 185, 129, 0.2);
        }

        .btn-new:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            background-color: #d1d5db;
        }

    .btn-replace {
        background-color: #ef4444;
        color: white;
    }

        .btn-replace:hover {
            background-color: #dc2626;
            box-shadow: 0 4px 6px rgba(220, 38, 38, 0.2);
        }

        .btn-replace:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            background-color: #d1d5db;
        }

    .btn-filter {
        background-color: #3b82f6;
        color: white;
    }

        .btn-filter:hover {
            background-color: #2563eb;
            box-shadow: 0 4px 6px rgba(59, 130, 246, 0.2);
        }

    .btn-export {
        background-color: #6366f1;
        color: white;
    }

        .btn-export:hover {
            background-color: #4f46e5;
            box-shadow: 0 4px 6px rgba(99, 102, 241, 0.2);
        }

    .table-card {
        background: white;
        border-radius: 8px;
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05), 0 2px 4px -1px rgba(0,0,0,0.03);
        border: 1px solid #e5e7eb;
        overflow-x: auto;
        max-height: 65vh;
    }

    .data-table {
        width: 100%;
        border-collapse: collapse;
        text-align: left;
        white-space: nowrap;
    }

        .data-table th {
            position: sticky;
            top: 0;
            background-color: #f9fafb;
            padding: 16px 20px;
            font-weight: bold;
            color: #4b5563;
            border-bottom: 2px solid #e5e7eb;
            font-size: 0.85rem;
            text-transform: uppercase;
            z-index: 10;
        }

        .data-table td {
            padding: 16px 20px;
            border-bottom: 1px solid #f3f4f6;
            color: #374151;
            font-size: 0.95rem;
        }

        .data-table tbody tr {
            transition: background-color 0.15s ease;
        }

            .data-table tbody tr:hover {
                background-color: #f8fafc;
            }

    .status-badge {
        background-color: #d1fae5;
        color: #065f46;
        padding: 4px 12px;
        border-radius: 9999px;
        font-size: 0.8rem;
        font-weight: 600;
        border: 1px solid #a7f3d0;
    }
</style>

<div style="max-width: 1400px; margin: 0 auto;">
    <h2 class="page-title">Mis Activos Fijos en Producción</h2>

    <div class="toolbar">
        <div class="toolbar-group">
            <button id="btnMover" class="btn-action btn-new" disabled onclick="abrirModalTraslado()">
                <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
                Traslado Interno
            </button>
            <button id="btnReportar" class="btn-action btn-replace" disabled onclick="abrirModalAveria()">
                <svg viewBox="0 0 24 24"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
                Reportar Falla <span id="txtSeleccion" style="background: white; color: #dc2626; padding: 2px 6px; border-radius: 10px; font-size: 0.75rem; margin-left: 5px;">0</span>
            </button>
        </div>

        <div class="toolbar-group" style="position: relative;">
            <div style="position: relative;">
                <svg style="position: absolute; left: 10px; top: 10px; color: #9ca3af;" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
                <input type="text" id="txtBuscarUniversal" onkeyup="aplicarFiltros()" placeholder="Buscar equipo o serie..." style="padding: 8px 10px 8px 32px; border: 1px solid #d1d5db; border-radius: 6px; width: 250px; outline: none;">
            </div>
            <button class="btn-action btn-export" onclick="exportarCSV()">
                <svg viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
                Exportar CSV
            </button>
            <button class="btn-action btn-filter" onclick="togglePanel(event, 'panelFiltros')">
                <svg viewBox="0 0 24 24"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"></polygon></svg>
                Filtros
            </button>
        </div>
    </div>

    <div id="panelFiltros" class="menu-flotante" style="display: none; background: white; border: 1px solid #3b82f6; border-radius: 8px; padding: 20px; margin-bottom: 20px;">
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px;">
            <div>
                <strong style="display: block; margin-bottom: 8px; font-size: 0.9rem; color: #1f2937;">Sede / Ambiente:</strong>
                <div style="max-height: 150px; overflow-y: auto; border: 1px solid #e5e7eb; padding: 10px; border-radius: 6px; background: #f8fafc;">
                    @foreach (var grupo in ubicacionesAgrupadas)
                    {
                        <div style="color: #1e40af; font-weight: bold; font-size: 0.85rem; margin-top: 5px; margin-bottom: 3px; border-bottom: 1px solid #e2e8f0;">🏢 @grupo.Key</div>
                        foreach (var ubi in grupo.Value)
                        {
                            <label style="display: block; margin-left: 15px; font-size: 0.85rem; color: #475569; cursor: pointer;">
                                <input type="checkbox" class="flt-ubicacion" value="@ubi.ToLower()"> @ubi.Split('-').Last().Trim()
                            </label>
                        }
                    }
                </div>
            </div>
            <div>
                <strong style="display:block; margin-bottom:8px; font-size: 0.9rem; color: #1f2937;">Categoría:</strong>
                <div style="max-height: 150px; overflow-y: auto; border: 1px solid #e5e7eb; padding: 10px; border-radius: 6px;">
                    @foreach (var c in categoriasUnicas)
                    {<label style="display:block; font-size: 0.85rem; margin-bottom: 4px;"><input type="checkbox" class="flt-categoria" value="@c.ToLower()"> @c</label>}
                </div>
            </div>
            <div>
                <strong style="display:block; margin-bottom:8px; font-size: 0.9rem; color: #1f2937;">Marca:</strong>
                <div style="max-height: 150px; overflow-y: auto; border: 1px solid #e5e7eb; padding: 10px; border-radius: 6px;">
                    @foreach (var m in marcasUnicas)
                    {<label style="display:block; font-size: 0.85rem; margin-bottom: 4px;"><input type="checkbox" class="flt-marca" value="@m.ToLower()"> @m</label>}
                </div>
            </div>
        </div>
        <div style="margin-top: 15px; text-align: right;">
            <button onclick="limpiarFiltros()" style="background:#f1f5f9; color:#475569; border:none; padding:8px 16px; border-radius:6px; font-weight:bold; cursor:pointer;">Limpiar</button>
            <button onclick="aplicarFiltros()" style="background:#3b82f6; color:white; border:none; padding:8px 24px; border-radius:6px; font-weight:bold; cursor:pointer;">Aplicar</button>
        </div>
    </div>

    <div class="table-card">
        <table class="data-table" id="tablaInventario">
            <thead>
                <tr>
                    <th style="width: 40px; text-align: center;"><input type="checkbox" onchange="seleccionarTodos(this)" style="cursor: pointer;" /></th>
                    <th>Etiqueta ID</th>
                    <th>Categoría</th>
                    <th>Equipo (Marca / Modelo)</th>
                    <th>Nro. Serie</th>
                    <th>Ubicación</th>
                    <th>Estado</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="7" style="padding: 60px; text-align: center; color: #6b7280;">No tienes activos vinculados actualmente.</td></tr>
                }
                else
                {
                    foreach (var item in Model)
                    {
                        <tr class="item-row">
                            <td style="text-align: center;">
                                <input type="checkbox" class="chk-item" value="@item.IdActivo" onchange="evaluarSeleccion()" style="cursor: pointer;" />
                            </td>
                            <td class="col-etiqueta" style="font-weight: bold; color: #1e40af;">@item.Etiqueta</td>
                            <td class="col-categoria">@item.Categoria</td>
                            <td class="col-marca">@item.Marca <span class="col-modelo" style="color: #6b7280; font-size: 0.85rem;">@item.Modelo</span></td>
                            <td style="font-family: monospace; color: #4b5563;">@(string.IsNullOrEmpty(item.Serie) ? "-" : item.Serie)</td>
                            <td class="col-ubicacion">@item.Ubicacion</td>
                            <td><span class="status-badge">@item.Estado</span></td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<div id="modalTraslado" class="modal-overlay">
    <div class="modal-box" onclick="event.stopPropagation()">
        <h3 style="margin-top:0; color:#1e40af; border-bottom:1px solid #eee; padding-bottom:10px;">Traslado Físico Interno</h3>
        <p style="color:#666; font-size:0.9rem;">Seleccione el nuevo ambiente de destino.</p>
        <select id="cboSedesModal" style="width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 5px; margin-bottom: 20px;"></select>
        <div style="text-align: right;">
            <button onclick="document.getElementById('modalTraslado').style.display='none'" style="padding: 8px 15px; cursor:pointer; background:#f1f5f9; color:#475569; border:none; border-radius:4px; margin-right:10px; font-weight:bold;">Cancelar</button>
            <button onclick="confirmarTraslado()" style="padding: 8px 15px; cursor:pointer; background:#10b981; color:white; border:none; border-radius:4px; font-weight:bold;">Confirmar Movimiento</button>
        </div>
    </div>
</div>

<div id="modalAveria" class="modal-overlay">
    <div class="modal-box" onclick="event.stopPropagation()">
        <h3 style="margin-top:0; color:#dc2626; border-bottom: 1px solid #eee; padding-bottom:10px;">Reportar Falla / Avería</h3>
        <p style="color: #64748b; font-size: 0.9rem; margin-bottom: 15px;">Al confirmar, el sistema notificará a BITATEL para su revisión y cambio.</p>

        <div style="margin-bottom: 20px;">
            <label style="display: block; font-weight: bold; font-size: 0.85rem; color: #4b5563; margin-bottom: 5px;">Describe el problema detalladamente:</label>
            <textarea id="txtMotivoFalla" rows="4" placeholder="Ej: La pantalla parpadea, disco duro hace ruido..." style="width: 100%; padding: 10px; border: 1px solid #cbd5e1; border-radius: 5px; box-sizing: border-box; font-family: inherit;"></textarea>
        </div>

        <div style="text-align: right;">
            <button onclick="document.getElementById('modalAveria').style.display='none'" style="padding: 10px 15px; cursor:pointer; background:#f1f5f9; color:#475569; border:none; border-radius:5px; font-weight:bold; margin-right:10px;">Cancelar</button>
            <button onclick="enviarReporteFalla()" style="padding: 10px 20px; cursor:pointer; background:#ef4444; color:white; border:none; border-radius:5px; font-weight:bold;">Enviar Reporte a BITATEL</button>
        </div>
    </div>
</div>

<script>
    // CONTROL DE PANELES FLOTANTES
    var panelFiltros = document.getElementById('panelFiltros');
    if (panelFiltros) panelFiltros.addEventListener('click', e => e.stopPropagation());

    function togglePanel(event, panelId) {
        event.stopPropagation();
        var panel = document.getElementById(panelId);
        var isOpen = panel.style.display === "block";
        if (document.getElementById('panelFiltros')) document.getElementById('panelFiltros').style.display = 'none';
        if (!isOpen) panel.style.display = "block";
    }

    window.onclick = function (e) {
        if (!e.target.closest('.btn-action') && !e.target.closest('.menu-flotante')) {
            if (document.getElementById('panelFiltros')) document.getElementById('panelFiltros').style.display = 'none';
        }
    }

    // SELECCIÓN Y BOTONES
    function seleccionarTodos(chkPrincipal) {
        document.querySelectorAll('.item-row').forEach(fila => {
            if (fila.style.display !== "none") {
                var chk = fila.querySelector('.chk-item');
                if (chk) chk.checked = chkPrincipal.checked;
            }
        });
        evaluarSeleccion();
    }

    function evaluarSeleccion() {
        var cant = document.querySelectorAll('.chk-item:checked').length;
        document.getElementById('txtSeleccion').innerText = cant;

        document.getElementById('btnMover').disabled = (cant === 0);
        document.getElementById('btnReportar').disabled = (cant === 0);
    }

    function obtenerIds() { return Array.from(document.querySelectorAll('.chk-item:checked')).map(chk => parseInt(chk.value)); }

    // ===============================================
    // LÓGICA TRASLADO INTERNO
    // ===============================================
    function abrirModalTraslado() {
        fetch('/Cliente/ObtenerMisUbicaciones')
            .then(res => res.json())
            .then(data => {
                var select = document.getElementById('cboSedesModal');
                select.innerHTML = '';
                data.forEach(u => select.innerHTML += `<option value="${u.id}">${u.texto}</option>`);
                document.getElementById('modalTraslado').style.display = 'flex';
            });
    }

    function confirmarTraslado() {
        var idDestino = document.getElementById('cboSedesModal').value;
        fetch('/Cliente/EjecutarTrasladoCliente', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ ids: obtenerIds(), idUbicacionDestino: idDestino })
        }).then(res => res.json()).then(data => {
            if (data.success) { alert("Traslado ejecutado con éxito."); location.reload(); }
            else alert("Error: " + data.message);
        });
    }

    // ===============================================
    // LÓGICA DE AVERÍAS
    // ===============================================
    function abrirModalAveria() {
        document.getElementById('txtMotivoFalla').value = '';
        document.getElementById('modalAveria').style.display = 'flex';
    }

    function enviarReporteFalla() {
        var motivo = document.getElementById('txtMotivoFalla').value;
        if (!motivo) { alert("Por favor describa la falla."); return; }

        if (confirm("¿Seguro que desea reportar estos equipos como averiados? Esto los dará de baja y notificará a BITATEL.")) {
            fetch('/Cliente/ReportarAveria', {
                method: 'POST', headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ ids: obtenerIds(), motivo: motivo })
            }).then(res => res.json()).then(data => {
                if (data.success) {
                    alert("✅ Equipos reportados con éxito. El equipo de soporte se contactará pronto.");
                    location.reload();
                }
                else alert("Error: " + data.message);
            });
        }
    }

    // ===============================================
    // FILTROS AVANZADOS Y BUSCADOR (Súper Rápido)
    // ===============================================
    function obtenerValoresChecked(clase) { return Array.from(document.querySelectorAll(clase + ':checked')).map(chk => chk.value); }

    function aplicarFiltros() {
        var textoBusqueda = document.getElementById("txtBuscarUniversal").value.toLowerCase();
        var ubis = obtenerValoresChecked('.flt-ubicacion');
        var cats = obtenerValoresChecked('.flt-categoria');
        var marcas = obtenerValoresChecked('.flt-marca');

        document.querySelectorAll(".item-row").forEach(function (fila) {
            var fTexto = fila.textContent.toLowerCase();
            var fUbi = fila.querySelector(".col-ubicacion").textContent.toLowerCase();
            var fCat = fila.querySelector(".col-categoria").textContent.toLowerCase();
            var fMarca = fila.querySelector(".col-marca").textContent.toLowerCase();

            var pTexto = textoBusqueda === "" || fTexto.includes(textoBusqueda);
            var pUbi = ubis.length === 0 || ubis.some(u => fUbi.includes(u));
            var pCat = cats.length === 0 || cats.some(c => fCat.includes(c));
            var pMarca = marcas.length === 0 || marcas.some(m => fMarca.includes(m));

            if (pTexto && pUbi && pCat && pMarca) {
                fila.style.display = "";
            } else {
                fila.style.display = "none";
                var chk = fila.querySelector(".chk-item");
                if (chk) chk.checked = false;
            }
        });
        evaluarSeleccion();
        if (document.getElementById('panelFiltros')) document.getElementById('panelFiltros').style.display = 'none';
    }

    function limpiarFiltros() {
        document.querySelectorAll('.menu-flotante input[type="checkbox"]').forEach(chk => chk.checked = false);
        document.getElementById("txtBuscarUniversal").value = "";
        aplicarFiltros();
    }

    // EXPORTAR A CSV (EXCEL)
    function exportarCSV() {
        var filasVisible = Array.from(document.querySelectorAll(".item-row")).filter(f => f.style.display !== "none");
        if (filasVisible.length === 0) { alert("No hay datos para exportar con los filtros actuales."); return; }

        var csv = "Etiqueta,Categoria,Marca,Modelo,Serie,Ubicacion,Estado\n";
        filasVisible.forEach(fila => {
            let cols = fila.querySelectorAll("td");
            let etiqueta = cols[1].innerText.trim();
            let cat = cols[2].innerText.trim();
            let marca = cols[3].querySelector(".col-marca") ? cols[3].innerText.split('\n')[0].trim() : cols[3].innerText.trim();
            let mod = cols[3].querySelector(".col-modelo") ? cols[3].querySelector(".col-modelo").innerText.trim() : "";
            let serie = cols[4].innerText.trim();
            let ubi = cols[5].innerText.trim();
            let estado = cols[6].innerText.trim();

            csv += `"${etiqueta}","${cat}","${marca}","${mod}","${serie}","${ubi}","${estado}"\n`;
        });

        var enlace = document.createElement("a");
        enlace.href = "data:text/csv;charset=utf-8," + encodeURIComponent(csv);
        enlace.download = "Mis_Activos_BITATEL.csv";
        document.body.appendChild(enlace);
        enlace.click();
        document.body.removeChild(enlace);
    }
</script>