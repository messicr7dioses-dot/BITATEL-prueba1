@model IEnumerable<BITATEL_prueba1.Models.ActivoCliente>

@{
    ViewBag.Title = "Activos Fijos";
    Layout = "~/Views/Shared/_LayoutCliente.cshtml";
}

<style>
    /* Cabecera y Título */
    .page-title {
        margin-top: 0;
        color: #1f2937;
        font-size: 1.8rem;
        font-weight: 600;
        margin-bottom: 25px;
    }

    /* Barra de herramientas (Botones) */
    .toolbar {
        display: flex;
        justify-content: space-between;
        margin-bottom: 20px;
        align-items: center;
    }

    .toolbar-group {
        display: flex;
        gap: 12px;
    }

    /* Diseño moderno de botones */
    .btn-action {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 10px 16px;
        border-radius: 6px;
        border: none;
        font-size: 0.9rem;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s ease;
        box-shadow: 0 1px 2px rgba(0,0,0,0.05);
    }

        .btn-action:active {
            transform: scale(0.97); /* Efecto de hundirse al dar clic */
        }

        .btn-action svg {
            width: 18px;
            height: 18px;
            fill: none;
            stroke: currentColor;
            stroke-width: 2;
            stroke-linecap: round;
            stroke-linejoin: round;
        }

    /* Colores por acción */
    .btn-new {
        background-color: #10b981;
        color: white;
    }

        .btn-new:hover {
            background-color: #059669;
            box-shadow: 0 4px 6px rgba(16, 185, 129, 0.2);
        }

    .btn-replace {
        background-color: #f59e0b;
        color: white;
    }

        .btn-replace:hover {
            background-color: #d97706;
            box-shadow: 0 4px 6px rgba(245, 158, 11, 0.2);
        }

    .btn-mod {
        background-color: #e5e7eb;
        color: #374151;
    }

        .btn-mod:hover {
            background-color: #d1d5db;
            color: #111827;
        }

    .btn-filter {
        background-color: #3b82f6;
        color: white;
    }

        .btn-filter:hover {
            background-color: #2563eb;
            box-shadow: 0 4px 6px rgba(59, 130, 246, 0.2);
        }

    .btn-export {
        background-color: #6366f1;
        color: white;
    }

        .btn-export:hover {
            background-color: #4f46e5;
            box-shadow: 0 4px 6px rgba(99, 102, 241, 0.2);
        }
    /* Contenedor de la Tabla */
    .table-card {
        background: white;
        border-radius: 8px;
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05), 0 2px 4px -1px rgba(0,0,0,0.03);
        border: 1px solid #e5e7eb;
        overflow: hidden;
    }

    /* La Tabla en sí */
    .data-table {
        width: 100%;
        border-collapse: collapse;
        text-align: left;
    }

        .data-table th {
            background-color: #f9fafb;
            padding: 16px 20px;
            font-weight: 600;
            color: #4b5563;
            border-bottom: 1px solid #e5e7eb;
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .data-table td {
            padding: 16px 20px;
            border-bottom: 1px solid #f3f4f6;
            color: #374151;
            font-size: 0.95rem;
        }

        .data-table tbody tr {
            transition: background-color 0.15s ease;
        }

            .data-table tbody tr:hover {
                background-color: #f3f6f9; /* Ilumina la fila al pasar el mouse */
            }

    /* Etiqueta de Estado */
    .status-badge {
        background-color: #d1fae5;
        color: #065f46;
        padding: 4px 12px;
        border-radius: 9999px; /* Forma de píldora */
        font-size: 0.8rem;
        font-weight: 600;
        display: inline-block;
    }

    /* Estado Vacío (Empty State) */
    .empty-state {
        padding: 60px 20px;
        text-align: center;
        color: #6b7280;
    }

        .empty-state svg {
            width: 64px;
            height: 64px;
            stroke: #9ca3af;
            margin-bottom: 15px;
        }

        .empty-state h3 {
            margin: 0 0 10px 0;
            color: #374151;
        }

        .empty-state p {
            margin: 0;
            font-size: 0.95rem;
        }
</style>

<h2 class="page-title">Mis Activos Fijos</h2>

<div class="toolbar">
    <div class="toolbar-group">
        <button class="btn-action btn-new" title="Generar nuevo contrato">
            <svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
            Solicitar Activo Nuevo
        </button>
        <button class="btn-action btn-replace" title="Reemplazo por garantía">
            <svg viewBox="0 0 24 24"><polyline points="23 4 23 10 17 10"></polyline><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"></path></svg>
            Solicitar Reemplazo
        </button>
    </div>

    <div class="toolbar-group">
        <button class="btn-action btn-mod" title="Editar detalles locales">
            <svg viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
            Modificar
        </button>
        <button class="btn-action btn-export" title="Exportar a CSV, PDF o TXT">
            <svg viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
            Exportar
        </button>
        <button class="btn-action btn-filter" title="Búsqueda avanzada">
            <svg viewBox="0 0 24 24"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"></polygon></svg>
            Filtros
        </button>
    </div>
</div>

<div class="table-card">
    <table class="data-table">
        <thead>
            <tr>
                <th style="width: 40px; text-align: center;">
                    <input type="checkbox" title="Seleccionar todos" style="cursor: pointer;" />
                </th>
                <th>Etiqueta</th>
                <th>Categoría</th>
                <th>Equipo</th>
                <th>Ubicación</th>
                <th>Estado</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td style="text-align: center;"><input type="checkbox" style="cursor: pointer;" /></td>
                    <td style="font-weight: 600; color: #0056b3;">@item.Etiqueta</td>
                    <td>@item.Categoria</td>
                    <td>@item.Marca @item.Modelo</td>
                    <td>@item.Ubicacion</td>
                    <td>
                        <span class="status-badge">@item.Estado</span>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect>
                <line x1="8" y1="21" x2="16" y2="21"></line>
                <line x1="12" y1="17" x2="12" y2="21"></line>
            </svg>
            <h3>Inventario en Blanco</h3>
            <p>Aún no tienes activos vinculados a contratos vigentes con BITATEL.</p>
        </div>
    }
</div>