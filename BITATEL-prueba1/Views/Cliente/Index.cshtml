@{
    ViewBag.Title = "Dashboard Cliente";
    Layout = "~/Views/Shared/_LayoutCliente.cshtml";
}

<h2 style="color: #333; margin-bottom: 25px;">Mi Resumen Operativo</h2>

<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px; margin-bottom: 30px;">

    <!-- TARJETA 1: INVENTARIO -->
    <a href="@Url.Action("MisActivos", "Cliente")" style="text-decoration: none; background: white; border-radius: 8px; padding: 25px; border-left: 5px solid #3b82f6; box-shadow: 0 4px 6px rgba(0,0,0,0.05); transition: transform 0.2s;" onmouseover="this.style.transform='translateY(-5px)'" onmouseout="this.style.transform='translateY(0)'">
        <div style="display: flex; align-items: center; gap: 8px; color: #64748b; font-weight: bold; font-size: 0.9rem; text-transform: uppercase;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect><line x1="8" y1="21" x2="16" y2="21"></line><line x1="12" y1="17" x2="12" y2="21"></line></svg>
            Mis Equipos Activos
        </div>
        <div style="font-size: 2.5rem; font-weight: bold; color: #1e293b; margin: 10px 0;">@ViewBag.TotalActivos</div>
        <div style="display: flex; align-items: center; gap: 5px; color: #3b82f6; font-size: 0.85rem; font-weight: bold;">
            Ver inventario <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
        </div>
    </a>

    <!-- TARJETA 2: SEDES -->
    <a href="@Url.Action("Ubicaciones", "Cliente")" style="text-decoration: none; background: white; border-radius: 8px; padding: 25px; border-left: 5px solid #10b981; box-shadow: 0 4px 6px rgba(0,0,0,0.05); transition: transform 0.2s;" onmouseover="this.style.transform='translateY(-5px)'" onmouseout="this.style.transform='translateY(0)'">
        <div style="display: flex; align-items: center; gap: 8px; color: #64748b; font-weight: bold; font-size: 0.9rem; text-transform: uppercase;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
            Mis Sedes y Áreas
        </div>
        <div style="font-size: 2.5rem; font-weight: bold; color: #1e293b; margin: 10px 0;">@ViewBag.TotalSedes</div>
        <div style="display: flex; align-items: center; gap: 5px; color: #10b981; font-size: 0.85rem; font-weight: bold;">
            Gestionar ubicaciones <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
        </div>
    </a>

    <!-- TARJETA 3: DEUDAS Y PAGOS -->
    <a href="@Url.Action("Deudas", "Cliente")" style="text-decoration: none; background: white; border-radius: 8px; padding: 25px; border-left: 5px solid #ef4444; box-shadow: 0 4px 6px rgba(0,0,0,0.05); transition: transform 0.2s;" onmouseover="this.style.transform='translateY(-5px)'" onmouseout="this.style.transform='translateY(0)'">
        <div style="display: flex; align-items: center; gap: 8px; color: #64748b; font-weight: bold; font-size: 0.9rem; text-transform: uppercase;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg>
            Pagos Pendientes
        </div>
        <div style="font-size: 2.5rem; font-weight: bold; color: #dc2626; margin: 10px 0;">$ @ViewBag.TotalDeuda.ToString("0.00")</div>
        <div style="display: flex; align-items: center; gap: 5px; color: #ef4444; font-size: 0.85rem; font-weight: bold;">
            Ver estado de cuenta <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
        </div>
    </a>
</div>