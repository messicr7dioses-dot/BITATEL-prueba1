@{
    if (Session["UsuarioActivo"] == null) { Response.Redirect(Url.Action("Index", "Login")); }
    var usuarioLogueado = Session["UsuarioActivo"] as BITATEL_prueba1.Models.Usuario;
    string nombreMostrar = usuarioLogueado != null ? usuarioLogueado.NombreCompleto : "Administrador";
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BITATEL Admin ERP</title>
    <style>
        body {
            margin: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            display: flex;
            height: 100vh;
            background-color: #f4f7f6;
            overflow: hidden;
        }

        .sidebar {
            width: 270px;
            background-color: #ffffff;
            border-right: 1px solid #e5e7eb;
            display: flex;
            flex-direction: column;
            transition: margin-left 0.3s ease;
            z-index: 1000;
            overflow-y: auto;
        }

            .sidebar::-webkit-scrollbar {
                width: 6px;
            }

            .sidebar::-webkit-scrollbar-thumb {
                background-color: #cbd5e1;
                border-radius: 10px;
            }

            .sidebar.collapsed {
                margin-left: -270px;
            }

        .sidebar-header {
            padding: 25px 20px;
            border-bottom: 1px solid #e5e7eb;
            text-align: center;
            font-weight: bold;
            font-size: 1.2rem;
            color: #1f2937;
        }

        .menu-category {
            padding: 15px 20px;
            font-size: 0.8rem;
            color: #6b7280;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-top: 10px;
            cursor: pointer;
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-weight: bold;
            transition: background 0.2s;
        }

            .menu-category:hover {
                background-color: #f3f4f6;
                color: #d97706;
            }

        .menu-category-left {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .submenu {
            display: none;
            background-color: #fafafa;
            border-bottom: 1px solid #f0f0f0;
        }

            .submenu.open {
                display: block;
            }

        .menu-item {
            padding: 12px 20px 12px 48px;
            text-decoration: none;
            color: #4b5563;
            display: block;
            transition: all 0.2s;
            font-size: 0.95rem;
        }

            .menu-item:hover {
                background-color: #fffbeb;
                border-left: 4px solid #d97706;
                color: #b45309;
                font-weight: 500;
            }

        .main-container {
            flex: 1;
            display: flex;
            flex-direction: column;
            transition: width 0.3s ease;
            min-width: 0;
        }

        .topbar {
            height: 65px;
            background-color: white;
            border-bottom: 1px solid #e5e7eb;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0 30px;
        }

        .topbar-right {
            display: flex;
            gap: 20px;
            align-items: center;
        }

        .topbar-btn {
            cursor: pointer;
            background: none;
            border: none;
            padding: 5px;
            color: #6b7280;
            display: flex;
            align-items: center;
            transition: color 0.3s;
        }

            .topbar-btn svg {
                width: 22px;
                height: 22px;
                stroke: currentColor;
                fill: none;
                stroke-width: 2;
                stroke-linecap: round;
                stroke-linejoin: round;
            }

            .topbar-btn:hover {
                color: #d97706;
            }

        .dropdown {
            position: relative;
            display: inline-block;
        }

        .dropdown-content {
            display: none;
            position: absolute;
            right: 0;
            top: 45px;
            background-color: #ffffff;
            min-width: 200px;
            box-shadow: 0px 8px 16px 0px rgba(0,0,0,0.15);
            border: 1px solid #e5e7eb;
            border-radius: 6px;
            z-index: 1000;
            overflow: hidden;
        }

            .dropdown-content a {
                color: #374151;
                padding: 14px 18px;
                text-decoration: none;
                display: flex;
                align-items: center;
                gap: 12px;
                font-size: 0.95rem;
                border-bottom: 1px solid #f0f0f0;
                transition: background 0.2s ease;
            }

                .dropdown-content a svg {
                    width: 18px;
                    height: 18px;
                    stroke: currentColor;
                    fill: none;
                    stroke-width: 2;
                    stroke-linecap: round;
                    stroke-linejoin: round;
                }

                .dropdown-content a:hover {
                    background-color: #f3f4f6;
                    color: #d97706;
                }

        .show-menu {
            display: block;
        }

        .content-area {
            padding: 30px;
            flex: 1;
            overflow-y: auto;
            overflow-x: hidden;
            background-color: #f4f7f6;
        }
    </style>
</head>
<body>
    <div class="sidebar" id="sidebar">
        <div class="sidebar-header">Panel ERP<br /><span style="color: #d97706; font-size: 1rem;">@nombreMostrar</span></div>

        <a href="@Url.Action("Index", "Admin")" style="padding: 15px 20px; text-decoration: none; color: #1f2937; font-weight: bold; display: flex; align-items: center; gap: 10px; border-bottom: 1px solid #eee; background: #fef3c7;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
            Dashboard Principal
        </a>

        <div class="menu-category" onclick="toggleMenu('menu-clientes')">
            <div class="menu-category-left"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="4" y="2" width="16" height="20" rx="2" ry="2"></rect><path d="M9 22v-4h6v4"></path><path d="M8 6h.01M16 6h.01M12 6h.01M12 10h.01M16 10h.01M8 10h.01M8 14h.01M12 14h.01M16 14h.01"></path></svg> Gestión de Clientes</div><span>▼</span>
        </div>
        <div class="submenu" id="menu-clientes">
            <a href="@Url.Action("Clientes", "Admin")" class="menu-item">Directorio de Clientes</a>
            <a href="@Url.Action("NuevoCliente", "Admin")" class="menu-item">Añadir Nuevo Cliente</a>
        </div>

        <div class="menu-category" onclick="toggleMenu('menu-activos')">
            <div class="menu-category-left"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect><line x1="8" y1="21" x2="16" y2="21"></line><line x1="12" y1="17" x2="12" y2="21"></line></svg> Activos y Logística</div><span>▼</span>
        </div>
        <div class="submenu" id="menu-activos">
            <a href="@Url.Action("GestionarStock", "Admin")" class="menu-item">Inventario Físico (Stock)</a>
            <a href="@Url.Action("Contratos", "Admin")" class="menu-item">Contratos Vigentes</a>
            <a href="@Url.Action("RegistrarAlquiler", "Admin")" class="menu-item" style="color: #059669; font-weight: bold;">Nuevo Contrato / Despacho</a>
        </div>

        <div class="menu-category" onclick="toggleMenu('menu-infra')">
            <div class="menu-category-left"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg> Infraestructura</div><span>▼</span>
        </div>
        <div class="submenu" id="menu-infra">
            <a href="@Url.Action("Ubicaciones", "Admin")" class="menu-item">Sedes y Ubicaciones</a>
        </div>

        <div class="menu-category" onclick="toggleMenu('menu-auditoria')">
            <div class="menu-category-left"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg> Auditoría</div><span>▼</span>
        </div>
        <div class="submenu" id="menu-auditoria">
            <a href="@Url.Action("Movimientos", "Admin")" class="menu-item">Historial de Movimientos</a>
            <a href="@Url.Action("Garantias", "Admin")" class="menu-item">Historial de Garantías</a>
        </div>

        <div class="menu-category" onclick="toggleMenu('menu-sistema')">
            <div class="menu-category-left"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg> Gestión de Usuarios</div><span>▼</span>
        </div>
        <div class="submenu" id="menu-sistema">
            <a href="@Url.Action("Usuarios", "Admin")" class="menu-item">Directorio de Usuarios</a>
        </div>
    </div>

    <div class="main-container">
        <div class="topbar">
            <button onclick="document.getElementById('sidebar').classList.toggle('collapsed')" class="topbar-btn">
                <svg viewBox="0 0 24 24"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
            </button>

            <div class="topbar-right">
                <a href="@Url.Action("Index", "Admin")" class="topbar-btn" title="Ir al Inicio"><svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg></a>

                <div class="dropdown">
                    <button onclick="toggleUserMenu(event)" class="topbar-btn"><svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg></button>
                    <div id="userDropdown" class="dropdown-content">
                        <a href="@Url.Action("Configuracion", "Admin")"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path></svg>Configuración</a>
                        <a href="@Url.Action("MiPerfil", "Admin")"><svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>Mi Perfil</a>
                        <a href="@Url.Action("Salir", "Login")" onclick="return confirm('¿Seguro que deseas salir?');" style="color:#dc2626;"><svg viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>Cerrar Sesión</a>
                    </div>
                </div>
            </div>
        </div>
        <div class="content-area">@RenderBody()</div>
    </div>

    <script>
        function toggleMenu(id) { document.getElementById(id).classList.toggle('open'); }
        function toggleUserMenu(event) { event.stopPropagation(); document.getElementById("userDropdown").classList.toggle("show-menu"); }
        window.onclick = function (e) { if (!e.target.closest('.topbar-btn') && !e.target.closest('.menu-flotante')) { var ud = document.getElementById("userDropdown"); if (ud) ud.classList.remove("show-menu"); document.querySelectorAll('.menu-flotante').forEach(m => m.style.display = 'none'); } }
    </script>
</body>
</html>