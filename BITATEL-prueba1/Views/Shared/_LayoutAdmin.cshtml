@{
    if (Session["UsuarioActivo"] == null) { Response.Redirect(Url.Action("Index", "Login")); }
    var user = Session["UsuarioActivo"] as BITATEL_prueba1.Models.Usuario;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - BITATEL Admin</title>
    <style>
        body {
            margin: 0;
            font-family: 'Segoe UI', sans-serif;
            display: flex;
            height: 100vh;
            background-color: #f8f9fa;
            overflow: hidden;
        }

        .sidebar {
            width: 260px;
            background-color: #ffffff;
            border-right: 2px solid #e0e0e0;
            display: flex;
            flex-direction: column;
            z-index: 1000;
        }

        .sidebar-header {
            padding: 30px 20px;
            border-bottom: 2px solid #e0e0e0;
            text-align: center;
            font-weight: bold;
            font-size: 1.2rem;
            color: #333;
        }

        .menu-item {
            padding: 15px 25px;
            text-decoration: none;
            color: #555;
            border-bottom: 1px solid #f0f0f0;
            display: block;
            transition: all 0.3s;
        }

            .menu-item:hover {
                background-color: #e9ecef;
                border-left: 5px solid #0056b3;
                color: #000;
            }

        .main-container {
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        .topbar {
            height: 60px;
            background-color: white;
            border-bottom: 2px solid #e0e0e0;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0 30px;
        }

        .topbar-right {
            display: flex;
            gap: 20px;
            align-items: center;
        }

        .topbar-btn {
            cursor: pointer;
            background: none;
            border: none;
            padding: 5px;
            color: #555;
            display: flex;
            align-items: center;
        }

        .content-area {
            padding: 30px;
            flex: 1;
            overflow-y: auto;
            background-color: #f4f7f6;
        }
    </style>
</head>
<body>
    <div class="sidebar" id="sidebar">
        <div class="sidebar-header">BITATEL ADMIN<br /><span style="color: #0056b3; font-size: 1rem;">@user.NombreCompleto</span></div>

        <a href="@Url.Action("Index", "Admin")" class="menu-item">Dashboard Admin</a>
        <a href="@Url.Action("RegistrarAlquiler", "Admin")" class="menu-item">Registrar Alquiler</a>
        <a href="@Url.Action("GestionarStock", "Admin")" class="menu-item">Gestionar Stock</a>
        <a href="@Url.Action("Usuarios", "Admin")" class="menu-item">Gestión de Usuarios</a>
        <a href="@Url.Action("Ubicaciones", "Admin")" class="menu-item">Ver Todas Ubicaciones</a>
        <a href="@Url.Action("Salir", "Login")" class="menu-item" style="color:#e11d48;">Cerrar Sesión</a>
    </div>

    <div class="main-container">
        <div class="topbar">
            <button class="topbar-btn">≡</button>
            <div class="topbar-right">
                <a href="@Url.Action("Index", "Admin")" class="topbar-btn">Inicio</a>
            </div>
        </div>
        <div class="content-area">@RenderBody()</div>
    </div>
</body>
</html>