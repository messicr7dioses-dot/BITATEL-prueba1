@{
    // Seguridad robusta: Si la sesión es nula, redirigimos al login
    if (Session["UsuarioActivo"] == null)
    {
        Response.Redirect(Url.Action("Index", "Login"));
    }

    var usuarioLogueado = Session["UsuarioActivo"] as BITATEL_prueba1.Models.Usuario;
    string nombreMostrar = usuarioLogueado != null ? usuarioLogueado.NombreCompleto : "Administrador";
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - BITATEL Admin</title>
    <style>
        body {
            margin: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            display: flex;
            height: 100vh;
            background-color: #f8f9fa;
            overflow: hidden;
        }

        /* SIDEBAR */
        .sidebar {
            width: 260px;
            background-color: #ffffff;
            border-right: 2px solid #e0e0e0;
            display: flex;
            flex-direction: column;
            transition: margin-left 0.3s ease;
            z-index: 1000;
        }

            .sidebar.collapsed {
                margin-left: -260px;
            }

        .sidebar-header {
            padding: 30px 20px;
            border-bottom: 2px solid #e0e0e0;
            text-align: center;
            font-weight: bold;
            font-size: 1.2rem;
            color: #333;
        }

        .menu-item {
            padding: 15px 25px;
            text-decoration: none;
            color: #555;
            border-bottom: 1px solid #f0f0f0;
            display: block;
            transition: all 0.3s;
        }

            .menu-item:hover {
                background-color: #e9ecef;
                border-left: 5px solid #d97706; /* Color naranja para diferenciar que es Admin */
                color: #000;
            }

        /* MAIN */
        .main-container {
            flex: 1;
            display: flex;
            flex-direction: column;
            transition: width 0.3s ease;
        }

        .topbar {
            height: 60px;
            background-color: white;
            border-bottom: 2px solid #e0e0e0;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0 30px;
        }

        .topbar-right {
            display: flex;
            gap: 20px;
            align-items: center;
        }

        .topbar-btn {
            cursor: pointer;
            background: none;
            border: none;
            padding: 5px;
            color: #555;
            display: flex;
            align-items: center;
            transition: color 0.3s;
        }

            .topbar-btn svg {
                width: 24px;
                height: 24px;
                stroke: currentColor;
                fill: none;
                stroke-width: 2;
                stroke-linecap: round;
                stroke-linejoin: round;
            }

            .topbar-btn:hover {
                color: #d97706;
            }

        /* DROPDOWN */
        .dropdown {
            position: relative;
            display: inline-block;
        }

        .dropdown-content {
            display: none;
            position: absolute;
            right: 0;
            top: 45px;
            background-color: #ffffff;
            min-width: 200px;
            box-shadow: 0px 8px 16px 0px rgba(0,0,0,0.15);
            border: 1px solid #ddd;
            border-radius: 6px;
            z-index: 1000;
            overflow: hidden;
        }

            .dropdown-content a {
                color: #374151;
                padding: 14px 18px;
                text-decoration: none;
                display: flex;
                align-items: center;
                gap: 12px;
                font-size: 0.95rem;
                border-bottom: 1px solid #f0f0f0;
                transition: all 0.2s ease;
            }

                .dropdown-content a svg {
                    width: 18px;
                    height: 18px;
                    stroke: currentColor;
                    fill: none;
                    stroke-width: 2;
                    stroke-linecap: round;
                    stroke-linejoin: round;
                }

                .dropdown-content a:hover {
                    background-color: #f3f4f6;
                    color: #d97706;
                }

        .show-menu {
            display: block;
        }

        .content-area {
            padding: 30px;
            flex: 1;
            overflow-y: auto;
            background-color: #f4f7f6;
        }
    </style>
</head>
<body>

    <div class="sidebar" id="sidebar">
        <div class="sidebar-header">Panel Admin<br /><span style="color: #d97706; font-size: 1rem;">@nombreMostrar</span></div>

        <div style="padding: 10px 20px; font-size: 0.75rem; color: #888; text-transform: uppercase; letter-spacing: 1px; margin-top: 10px;">Administración</div>
        <a href="@Url.Action("Index", "Admin")" class="menu-item">Dashboard Admin</a>
        <a href="@Url.Action("RegistrarAlquiler", "Admin")" class="menu-item">Registrar Alquiler</a>
        <a href="@Url.Action("GestionarStock", "Admin")" class="menu-item">Gestionar Stock</a>
        <a href="@Url.Action("Usuarios", "Admin")" class="menu-item">Gestión de Usuarios</a>

        <div style="padding: 10px 20px; font-size: 0.75rem; color: #888; text-transform: uppercase; letter-spacing: 1px; margin-top: 10px;">Consultas</div>
        <a href="@Url.Action("Ubicaciones", "Admin")" class="menu-item">Ver Todas Ubicaciones</a>

        <div style="padding: 10px 20px; font-size: 0.75rem; color: #888; text-transform: uppercase; letter-spacing: 1px; margin-top: 10px;">Logística</div>
        <a href="@Url.Action("Contratos", "Admin")" class="menu-item">Contratos</a>
        <a href="@Url.Action("Solicitudes", "Admin")" class="menu-item">Solicitudes</a>

        
    </div>

    <div class="main-container">
        <div class="topbar">
            <button onclick="toggleSidebar()" class="topbar-btn"><svg viewBox="0 0 24 24"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg></button>

            <div class="topbar-right">
                <a href="@Url.Action("Index", "Admin")" class="topbar-btn"><svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg></a>

                <div class="dropdown">
                    <button onclick="toggleUserMenu()" class="topbar-btn"><svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg></button>
                    <div id="userDropdown" class="dropdown-content">
                        <a href="@Url.Action("Configuracion", "Admin")"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a..."></path></svg>Configuración</a>
                        <a href="@Url.Action("MiPerfil", "Admin")"><svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>Mi Perfil</a>

                        <a href="@Url.Action("Salir", "Login")" onclick="return confirm('¿Seguro que deseas salir?');"><svg viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline></svg>Cerrar Sesión</a>
                    </div>
                </div>
            </div>
        </div>
        <div class="content-area">@RenderBody()</div>
    </div>

    <script>
        function toggleSidebar() { document.getElementById("sidebar").classList.toggle("collapsed"); }
        function toggleUserMenu() { document.getElementById("userDropdown").classList.toggle("show-menu"); }
        window.onclick = function (e) { if (!e.target.closest('.topbar-btn')) { document.getElementById("userDropdown").classList.remove("show-menu"); } }
    </script>
</body>
</html>